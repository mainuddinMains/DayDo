# ── Supabase ──────────────────────────────────────────────────────────────────
# Create a project at: https://supabase.com/dashboard
# Settings → API → copy "Project URL" and "anon public" key
# Auth → Providers → enable Google and paste your Google OAuth credentials
# Auth → URL Configuration → add your Vercel deployment URL to "Redirect URLs"
#   e.g. https://daydo.vercel.app
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# ── Google Tasks OAuth2 (Authorization Code + PKCE) ──────────────────────────
# Create credentials at: https://console.cloud.google.com/apis/credentials
# Application type: Web application
# Authorised redirect URIs: add both localhost and your production URL
#   http://localhost:5173
#   https://daydo.vercel.app
# Enable "Tasks API" in APIs & Services → Library
VITE_GOOGLE_CLIENT_ID=
# Local dev:
# VITE_GOOGLE_REDIRECT_URI=http://localhost:5173
# Production (set this in Vercel dashboard under Environment Variables):
VITE_GOOGLE_REDIRECT_URI=https://daydo.vercel.app

# ── Slack OAuth2 ──────────────────────────────────────────────────────────────
# Create an app at: https://api.slack.com/apps
# OAuth & Permissions → Redirect URLs: add both localhost and your production URL
#   http://localhost:5173
#   https://daydo.vercel.app
# Required Bot Token Scopes: search:read, stars:read, users:read
# Required User Token Scopes: search:read, stars:read
VITE_SLACK_CLIENT_ID=
VITE_SLACK_CLIENT_SECRET=
# Local dev:
# VITE_SLACK_REDIRECT_URI=http://localhost:5173
# Production (set this in Vercel dashboard under Environment Variables):
VITE_SLACK_REDIRECT_URI=https://daydo.vercel.app
