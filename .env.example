# ── Supabase ──────────────────────────────────────────────────────────────────
# Create a project at: https://supabase.com/dashboard
# Settings → API → copy "Project URL" and "anon public" key
# Auth → Providers → enable Google and paste your Google OAuth credentials
# Auth → URL Configuration → add http://localhost:5173 to "Redirect URLs"
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# ── Google Tasks OAuth2 (Authorization Code + PKCE) ──────────────────────────
# Create credentials at: https://console.cloud.google.com/apis/credentials
# Application type: Web application
# Authorised redirect URIs: add VITE_GOOGLE_REDIRECT_URI below
# Enable "Tasks API" in APIs & Services → Library
VITE_GOOGLE_CLIENT_ID=
VITE_GOOGLE_REDIRECT_URI=http://localhost:3000

# ── Slack OAuth2 ──────────────────────────────────────────────────────────────
# Create an app at: https://api.slack.com/apps
# OAuth & Permissions → Redirect URLs: add VITE_SLACK_REDIRECT_URI below
# Required Bot Token Scopes: search:read, stars:read, users:read
# Required User Token Scopes: search:read, stars:read
VITE_SLACK_CLIENT_ID=
VITE_SLACK_CLIENT_SECRET=
VITE_SLACK_REDIRECT_URI=http://localhost:3000
